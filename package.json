{
  "name": "playground-projects",
  "version": "1.0.0",
  "private": true,
  "description": "Platform monorepo with NestJS API and Expo mobile app",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.19.4"
  },
  "scripts": {
    "api:start": "npm run start:dev --workspace api",
    "api:build": "npm run build --workspace api",
    "api:test": "npm run test --workspace api",
    "mobile:start": "npm run start --workspace mobile",
    "mobile:ios": "npm run ios --workspace mobile",
    "mobile:android": "npm run android --workspace mobile",
    "mobile:web": "npm run web --workspace mobile"
  },
  "keywords": [],
