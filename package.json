{
  "name": "playground-projects",
  "version": "1.0.0",
  "private": true,
  "description": "Platform monorepo with NestJS API and Expo mobile app",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "api:install": "cd apps/api && npm install",
    "api:start": "cd apps/api && npm run start:dev",
    "api:build": "cd apps/api && npm run build",
    "api:test": "cd apps/api && npm run test",
    "api:prisma:generate": "cd apps/api && npm run prisma:generate",
    "api:prisma:migrate": "cd apps/api && npm run prisma:migrate:dev",
    "mobile:install": "cd apps/mobile && npm install",
    "mobile:start": "cd apps/mobile && npm run start",
    "mobile:ios": "cd apps/mobile && npm run ios",
    "mobile:android": "cd apps/mobile && npm run android",
    "mobile:web": "cd apps/mobile && npm run web",
    "typecheck": "cd apps/api && npm run typecheck && cd ../mobile && npm run typecheck"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
